# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================

# PostgreSQL — run: npm run db:up  (Docker Compose)
DATABASE_URL="postgresql://catprep:catprep@localhost:5432/catprep?schema=public"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_secret
NEXTAUTH_URL=http://localhost:3000

# Seed demo accounts (user@test.com / admin@test.com) — set false in production
SEED_DEMO_USERS=true

NODE_ENV=development

# =============================================================================
# PRODUCTION (Vercel + Neon / Supabase / Railway)
# =============================================================================
# Copy these into Vercel → Project → Settings → Environment Variables
#
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#   ↑ Use Neon's *pooled* connection string for serverless (add ?sslmode=require)
#
# DIRECT_URL=postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
#   ↑ Optional: Neon's *direct* URL — only needed if you use prisma migrate
#
# NEXTAUTH_SECRET=<run: openssl rand -base64 32>
# NEXTAUTH_URL=https://fleabag-cat-prep.vercel.app
#
# SEED_DEMO_USERS=false
# NODE_ENV=production
